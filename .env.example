# HuggingFace Token (Required for pyannote.audio)
# Get your token from: https://huggingface.co/settings/tokens
# You need to accept the terms for pyannote models at:
# https://huggingface.co/pyannote/speaker-diarization-3.1
# https://huggingface.co/pyannote/segmentation-3.0
HUGGINGFACE_TOKEN=your_token_here

# Directory Configuration
TEMP_DIR=./temp
MODELS_DIR=./models

# Model Configuration
WHISPER_MODEL_SIZE=base
# Options: tiny, base, small, medium, large-v2, large-v3
#
# CPU Performance Guide (for 4 vCPU, processing 1-hour video):
# - tiny:   3-5 min   (39M params, fast, acceptable accuracy)
# - base:   5-10 min  (74M params, good balance) ← RECOMMENDED for CPU
# - small:  15-30 min (244M params, better accuracy, much slower)
# - medium: 45-90 min (769M params, high accuracy, very slow)
# Note: Larger models require more RAM (2-8GB depending on size)

# Processing Limits
MAX_VIDEO_LENGTH_MINUTES=120

# Supported Languages
SUPPORTED_LANGUAGES=en,th

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO
