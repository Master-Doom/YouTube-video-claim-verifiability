# HuggingFace Token (Required for pyannote.audio)
# Get your token from: https://huggingface.co/settings/tokens
# You need to accept the terms for pyannote models at:
# https://huggingface.co/pyannote/speaker-diarization-3.1
# https://huggingface.co/pyannote/segmentation-3.0
HUGGINGFACE_TOKEN=your_token_here

# Directory Configuration
TEMP_DIR=./temp
MODELS_DIR=./models

# =============================================================================
# Model Configuration - Hardware-Specific
# =============================================================================
# The service automatically detects GPU/CPU and selects the appropriate model.
# Thai language benefits significantly from larger models for better accuracy.

# GPU Model Size (used when CUDA is available)
# Options: tiny, base, small, medium, large-v2, large-v3
# Recommended: medium for best Thai accuracy on GPU
WHISPER_MODEL_SIZE_GPU=medium

# CPU Model Size (used when CUDA is not available)
# Options: tiny, base, small, medium, large-v2, large-v3
# Recommended: small for balanced accuracy/speed on CPU
WHISPER_MODEL_SIZE_CPU=small

# [OPTIONAL] Manual Override - if set, ignores auto-detection
# Leave empty or commented out to use automatic hardware-based selection
# WHISPER_MODEL_SIZE=

# =============================================================================
# Performance Guide
# =============================================================================
# GPU Performance (RTX 3080/A100, 1-hour video):
#   - small:   ~2-3 min
#   - medium:  ~4-6 min  <- Recommended for Thai on GPU
#   - large:   ~8-12 min
#
# CPU Performance (4 vCPU, 1-hour video):
#   - tiny:    ~5 min    (lower accuracy)
#   - base:    ~10 min
#   - small:   ~20 min   <- Recommended for Thai on CPU
#   - medium:  ~60+ min  (not recommended for CPU)

# Processing Limits
MAX_VIDEO_LENGTH_MINUTES=120

# Supported Languages
SUPPORTED_LANGUAGES=en,th

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO

# =============================================================================
# Fact-Checking Configuration (Part 2)
# =============================================================================

# Google Gemini API (Required for fact-checking)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model (optional, defaults to gemini-1.5-flash)
# Options: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-exp
GEMINI_MODEL=gemini-1.5-flash

# Gemini rate limit (free tier: 15 requests/minute)
GEMINI_REQUESTS_PER_MINUTE=15

# SerpAPI (Required for evidence retrieval)
# Get your API key from: https://serpapi.com/manage-api-key
SERPAPI_API_KEY=your_serpapi_api_key_here

# Fact-Checking Options
ENABLE_FACT_CHECKING=true
MAX_CLAIMS_TO_VERIFY=10
EVIDENCE_SOURCES_PER_CLAIM=5

# =============================================================================
# YouTube Bot Detection Bypass (for Data Center IPs like RunPod)
# =============================================================================
# If you get "Sign in to confirm you're not a bot" error when running on
# cloud/data center servers, you can provide YouTube cookies for authentication.
#
# How to get cookies:
# 1. Install browser extension: "Get cookies.txt LOCALLY" (Chrome/Firefox)
# 2. Log into YouTube in your browser
# 3. Visit youtube.com and export cookies to cookies.txt
# 4. Place the file in your project or mount it in Docker
#
# Docker usage:
#   docker run -v /path/to/cookies.txt:/app/cookies.txt \
#     -e YOUTUBE_COOKIES_PATH=/app/cookies.txt ...
#
# Leave empty if not needed (works fine on residential IPs)
YOUTUBE_COOKIES_PATH=
